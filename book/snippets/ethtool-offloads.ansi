$ sudo fdctl configure init ethtool-offloads
[32mNOTICE [0m ethtool-offloads ... unconfigured ... device `ens3f0np0` has rx-udp-gro-forwarding enabled. Should be disabled
[32mNOTICE [0m ethtool-offloads ... configuring
[32mNOTICE [0m RUN: `ethtool --features ens3f0np0 rx-udp-gro-forwarding off`
[32mNOTICE [0m RUN: `ethtool --features ens3f0np0 tx-gre-segmentation off`
[32mNOTICE [0m RUN: `ethtool --features ens3f0np0 tx-gre-csum-segmentation off`

$ ethtool --show-offload ens3f0np0 | grep rx-udp-gro-forwarding
rx-udp-gro-forwarding: off

$ ethtool --show-offload ens3f0np0 | grep tx-gre-segmentation
tx-gre-segmentation: off
